{
  "name": "video-compressor",
  "version": "1.0.0",
  "description": "Local video compression app with hardware-accelerated encoding for Apple Silicon",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{js,json,css,html}'",
    "format:check": "prettier --check '**/*.{js,json,css,html}'",
    "check": "npm run lint && npm run format:check",
    "security": "npm audit"
  },
  "dependencies": {
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "open": "^10.1.0",
    "p-queue": "^8.0.1",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "type": "module",
  "devDependencies": {
    "eslint": "^10.0.1",
    "prettier": "^3.8.1"
  }
}
